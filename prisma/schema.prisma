generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               Int           @id @default(autoincrement())
  name             String
  email            String        @unique
  password         String
  role             String        @default("CLIENT") // ADMIN, VENDOR, CLIENT
  createdAt        DateTime      @default(now())

  // Vendor Specific Fields
  vendorCode       String?       @unique
  qrCodeUrl        String?

  // Relation: Client belongs to a Vendor
  vendorId         Int?
  vendor           User?         @relation("VendorClients", fields: [vendorId], references: [id])
  clients          User[]        @relation("VendorClients")

  // Vendor's products
  products         Product[]     @relation("VendorProducts")

  // Client's orders
  clientOrders     Order[]       @relation("ClientOrders")
  
  // Vendor's received orders
  vendorOrders     Order[]       @relation("VendorOrders")

  // Chat system
  sentMessages     ChatMessage[] @relation("MessageSender")
  receivedMessages ChatMessage[] @relation("MessageReceiver")
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  price       Float
  imageUrl    String?
  createdAt   DateTime    @default(now())
  
  vendorId    Int
  vendor      User        @relation("VendorProducts", fields: [vendorId], references: [id])
  
  orderItems  OrderItem[]
}

model Order {
  id                Int         @id @default(autoincrement())
  total             Float
  status            String      @default("PENDING") // PENDING, PAID, CANCELLED
  createdAt         DateTime    @default(now())
  
  clientId          Int
  client            User        @relation("ClientOrders", fields: [clientId], references: [id])
  
  vendorId          Int
  vendor            User        @relation("VendorOrders", fields: [vendorId], references: [id])
  
  items             OrderItem[]
  
  // Order Details
  fullName          String
  idNumber          String      // Cédula
  phone             String
  address           String
  
  // Payment
  paymentMethod     String      // CASH, USD, BS, PAGO_MOVIL, TRANSFERENCIA
  paymentReceiptUrl String?
  creditDate        DateTime?   // For "Días de crédito"
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  quantity  Int
  price     Float
  
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  
  productId Int
  product   Product @relation(fields: [productId], references: [id])
}

model ChatMessage {
  id         Int      @id @default(autoincrement())
  content    String?
  imageUrl   String?  // For uploading receipts
  createdAt  DateTime @default(now())
  
  senderId   Int
  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
  
  receiverId Int
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id])
}
